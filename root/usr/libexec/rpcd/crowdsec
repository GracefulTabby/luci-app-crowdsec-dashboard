. /lib/functions.sh
. /usr/share/libubox/jshn.sh

CSCLI="/usr/bin/cscli"

# Check if cscli exists
check_cscli() {
	if [ ! -x "$CSCLI" ]; then
		echo '{"error": "cscli not found"}'
		exit 1
	fi
}

# Validate IPv4 address or IPv4 CIDR range (e.g. 1.2.3.4 or 1.2.3.0/24)
validate_ip() {
	local ip="$1"
	echo "$ip" | grep -qE \
		'^(([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])\.){3}([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])(\/([0-9]|[1-2][0-9]|3[0-2]))?$'
}

# Validate duration format accepted by cscli (e.g. 4h, 30m, 7d, 60s)
validate_duration() {
	local dur="$1"
	echo "$dur" | grep -qE '^[0-9]+(s|m|h|d)$'
}

# Get decisions list
get_decisions() {
	check_cscli
	local output
	output=$($CSCLI decisions list -o json 2>/dev/null)
	if [ -z "$output" ] || [ "$output" = "null" ]; then
		echo '[]'
	else
		echo "$output"
	fi
}

# Get alerts list
get_alerts() {
	local limit="${1:-50}"
	check_cscli
	local output
	output=$($CSCLI alerts list -o json --limit "$limit" 2>/dev/null)
	if [ -z "$output" ] || [ "$output" = "null" ]; then
		echo '[]'
	else
		echo "$output"
	fi
}


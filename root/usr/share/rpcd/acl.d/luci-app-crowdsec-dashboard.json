{
	"luci-app-crowdsec-dashboard": {
		"description": "Grant access to LuCI CrowdSec Dashboard",
		"read": {
			"ubus": {
				"crowdsec": [ "decisions", "alerts", "metrics", "bouncers", "machines", "hub", "status", "stats" ],
				"file": [ "read", "stat" ]
			},
			"uci": [ "crowdsec" ]
		},
		"write": {
			"ubus": {
				"crowdsec": [ "ban", "unban" ]
			}
		}
	}
}
